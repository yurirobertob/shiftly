# Database (Neon)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Auth.js v5
AUTH_SECRET=  # Generate with: npx auth secret
AUTH_URL=https://shiftsly.com         # Production base URL (set in Vercel env)
AUTH_TRUST_HOST=true                  # Required on custom domains
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_RESEND_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=

# App
NEXT_PUBLIC_APP_URL=https://shiftsly.com

# Usability Test
NEXT_PUBLIC_SHIFTLY_URL=https://app.shiftsly.com   # URL of the Shiftly test environment
NEXT_PUBLIC_DISCOUNT_CODE=BETA3MESES               # Discount code shown at end of test

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL="Shiftsly <noreply@shiftsly.com>"

# Growth Agent (Telegram)
TELEGRAM_BOT_TOKEN=                                  # BotFather token
TELEGRAM_USER_ID=                                    # Your numeric user id (single recipient)
TELEGRAM_WEBHOOK_SECRET=                             # Random string — passed to setWebhook secret_token
CRON_SECRET=                                         # Random string — Vercel Cron sends Authorization: Bearer <CRON_SECRET>
